# Local .terraform directories
**/.terraform/*

# .tfstate files
*.tfstate
*.tfstate.*

# Crash log files
crash.log
crash.*.log

# Exclude override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Include override directories
!override.tf/
!override.tf.json/

# Exclude terraform.tfvars containing configurations
*.tfvars
*.tfvars.json

# Local execution variables
plan.out
